; CHECK-NEXT:    vsqrt.f64 d17, d16
; CHECK-NEXT:    vmul.f64 d0, d16, d17
; CHECK-NEXT:    bx lr
  %r = call nsz ninf afn double @llvm.pow.f64(double %x, double 7.5e-01)
