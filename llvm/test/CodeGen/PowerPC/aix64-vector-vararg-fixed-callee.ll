  ; CHECK-NEXT:   STD [[COPY1]], 8, %fixed-stack.0 :: (store (s64) into %fixed-stack.0 + 8)
  ; CHECK-NEXT:   STD [[COPY2]], 0, %fixed-stack.0 :: (store (s64) into %fixed-stack.0)
  ; CHECK-NEXT:   LIFETIME_START %stack.0.arg_list
  ; CHECK-NEXT:   [[ADDI8_:%[0-9]+]]:g8rc = ADDI8 %fixed-stack.0, 15
  ; CHECK-NEXT:   [[RLDICR:%[0-9]+]]:g8rc_and_g8rc_nox0 = RLDICR killed [[ADDI8_]], 0, 59
  ; CHECK-NEXT:   [[LFD:%[0-9]+]]:f8rc = LFD 16, killed [[RLDICR]] :: (load (s64) from %ir.argp.next, align 16)
  ; CHECK-NEXT:   LIFETIME_END %stack.0.arg_list
